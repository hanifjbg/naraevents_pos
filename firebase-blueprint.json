{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the POS system",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "name": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["username", "name", "role", "pin"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the POS menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "price", "category"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A completed checkout transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "shiftId": { "type": "string" },
        "cashier": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "cashReceived": { "type": "number" },
        "change": { "type": "number" }
      },
      "required": ["id", "timestamp", "cashier", "items", "total", "paymentMethod"]
    },
    "Shift": {
      "title": "Shift",
      "description": "A cashier shift log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "cashierUsername": { "type": "string" },
        "cashierName": { "type": "string" },
        "startingCash": { "type": "number" },
        "actualCash": { "type": "number" },
        "expectedCash": { "type": "number" },
        "totalSales": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "closed"] }
      },
      "required": ["id", "startTime", "cashierUsername", "cashierName", "startingCash", "totalSales", "status"]
    }
  },
  "firestore": {
    "users": {
        "schema": { "$ref": "User" },
        "description": "Users"
    },
    "menu": {
        "schema": { "$ref": "Product" },
        "description": "Menu items"
    },
    "transactions": {
        "schema": { "$ref": "Transaction" },
        "description": "Transactions"
    },
    "shifts": {
        "schema": { "$ref": "Shift" },
        "description": "Shifts"
    }
  }
}
