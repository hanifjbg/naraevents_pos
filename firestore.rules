rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // POS tables
    match /users/{userId} {
      allow read, write: if true;
    }
    match /menu/{menuId} {
      allow read, write: if true;
    }
    match /transactions/{transactionId} {
      allow read, write: if true;
    }
    match /shifts/{shiftId} {
      allow read, write: if true;
    }
    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

